# Copy to ~/.mempalace/remote/env  (chmod 600) and fill in.
# The only required value is the passphrase you'll type at the login page.

MEMPALACE_REMOTE_PASSPHRASE="change-me-to-a-long-secret"

# Public URL Tailscale Funnel publishes. Must match the funnel port (:8443).
PUBLIC_BASE_URL="https://your-machine.your-tailnet.ts.net:8443"

# Local bind (Funnel forwards :8443 -> here). Defaults shown.
BIND_HOST="127.0.0.1"
BIND_PORT="8789"

# Interpreter that run.sh launches the service with. Defaults to the mempalace
# uv tool venv, which is what `uv tool install mempalace` gives you. Set this
# only if mempalace lives somewhere else (another venv, a source checkout).
# Scope: this file configures the service. The other scripts in this repo take
# MEMPALACE_PYTHON from the shell instead (MEMPALACE_PYTHON=... ./script.sh).
# MEMPALACE_PYTHON="$HOME/.local/share/uv/tools/mempalace/bin/python"
